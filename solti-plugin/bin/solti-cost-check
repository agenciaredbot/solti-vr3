#!/usr/bin/env bash
# Show today's accumulated spend.
# Usage: bin/solti-cost-check
# Output: Single line with today's cost and credit info

HUB_URL="${SOLTI_HUB_URL:-http://localhost:4000}"
API_KEY="${SOLTI_API_KEY:-}"

if [ -z "$API_KEY" ] || [ "$API_KEY" = "" ]; then
  echo "Cost: UNKNOWN — No Hub API key configured (standalone mode)"
  exit 0
fi

result=$(curl -s --max-time 3 \
  -H "Authorization: Bearer $API_KEY" \
  "$HUB_URL/api/analytics/today-cost" 2>/dev/null)

if [ $? -eq 0 ] && [ -n "$result" ]; then
  echo "$result" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    total = data.get('total_cost', 0)
    credits_used = data.get('credits_used', 0)
    credits_remaining = data.get('credits_remaining', '?')
    print(f\"Today's spend: \${total:.2f} ({credits_used} credits used)\")
    print(f\"Credits remaining: {credits_remaining}\")
except Exception:
    print('Cost: Unable to parse response')
" 2>/dev/null || echo "Cost: Unable to parse response"
else
  echo "Cost: Unable to reach Hub — running in standalone mode"
fi
